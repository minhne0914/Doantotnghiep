# =====================================================================
# Mẫu file biến môi trường cho dự án Medic.
# Copy thành .env (KHÔNG commit file .env lên git) và điền giá trị thật.
# Tạo SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
# =====================================================================

# --- Django ---
DJANGO_SECRET_KEY=replace-with-strong-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Redis & Celery (False khi dev không có Redis) ---
USE_REDIS_SERVICES=False

# --- Database (chọn 1 trong 2: sqlite cho dev nhanh, mysql cho production) ---
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

DB_ENGINE=django.db.backends.mysql
DB_NAME=db_healthcare
DB_USER=app_user
DB_PASSWORD=replace-with-strong-password
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Email / SMTP ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Medic <noreply@example.com>

# --- Celery / Channels (Redis) ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=True
CHANNEL_LAYER_BACKEND=inmemory
CHANNEL_REDIS_URL=redis://127.0.0.1:6379/2

# --- Google Gemini (lấy key tại https://aistudio.google.com/) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- X-Ray upload (pneumonia detector) ---
MAX_XRAY_UPLOAD_BYTES=5242880
ALLOWED_XRAY_CONTENT_TYPES=image/jpeg,image/png,image/webp

# --- File upload limits chung ---
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880

# --- SMS provider (tùy chọn) ---
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Appointment policy ---
APPOINTMENT_CHANGE_DEADLINE_HOURS=4

# --- Production-only (set khi DEBUG=False) ---
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=2592000
# USE_FORWARDED_PROTO=True
